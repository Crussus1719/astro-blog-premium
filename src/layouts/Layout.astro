---
interface Props {
	title: string;
	description?: string;
	image?: string;
}

const { title, description = "Um blog premium construído com Astro, Tailwind e Decap CMS.", image = "/placeholder-social.jpg" } = Astro.props;

import '../styles/global.css';
import { Github, Search, Menu, X, Sun, Moon } from 'lucide-astro';
import { ViewTransitions } from 'astro:transitions';
---

<!doctype html>
<html lang="pt-br" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Astro Blog Premium</title>
		<ViewTransitions />

		<!-- Preconnect and DNS Prefetch -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link rel="dns-prefetch" href="https://fonts.googleapis.com">

		<!-- Non-blocking Google Fonts loading -->
		<link 
			rel="preload" 
			as="style" 
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=Playfair+Display:ital,wght@0,700;1,700&display=swap"
		/>
		<link 
			rel="stylesheet" 
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=Playfair+Display:ital,wght@0,700;1,700&display=swap" 
			media="print" 
			onload="this.media='all'"
		/>
		<noscript>
			<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=Playfair+Display:ital,wght@0,700;1,700&display=swap" rel="stylesheet" />
		</noscript>

		<!-- Open Graph / Social Meta -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />
		<meta name="twitter:card" content="summary_large_image" />

		<!-- Netlify Identity Widget -->
		<script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
	</head>
	<body class="flex flex-col min-h-screen">
		<!-- Header / Navigation -->
		<header class="sticky top-0 z-50 glass-effect border-b border-white/5 py-4 px-6 md:px-12 backdrop-blur-md">
			<nav class="max-w-7xl mx-auto flex items-center justify-between">
				<a href="/" class="flex items-center space-x-2 text-2xl font-serif font-black italic text-transparent bg-clip-text bg-gradient-to-r from-brand-primary to-brand-secondary">
					AstroBlog
				</a>

				<div class="hidden md:flex items-center space-x-8 text-sm font-semibold tracking-wide">
					<a href="/" class="hover:text-brand-primary transition-colors">Início</a>
					<a href="/blog" class="hover:text-brand-primary transition-colors">Blog</a>
					<a href="/quem-sou-eu" class="hover:text-brand-primary transition-colors">Sobre</a>
					<a href="/archive" class="hover:text-brand-primary transition-colors">Arquivo</a>
				</div>

				<div class="flex items-center space-x-4">
					<button class="p-2 animated-glow rounded-full text-slate-400 hover:text-white transition-all transform hover:rotate-12" aria-label="Toggle Theme" id="theme-toggle">
						<Sun size={20} class="hidden dark:block" />
						<Moon size={20} class="block dark:hidden" />
					</button>
					<button class="p-2 animated-glow rounded-full text-slate-400 hover:text-white" aria-label="Busca" id="search-btn">
						<Search size={22} />
					</button>
					<a href="https://github.com" target="_blank" class="p-2 animated-glow rounded-full text-slate-400 hover:text-white" aria-label="GitHub">
						<Github size={22} />
					</a>
					<button class="md:hidden p-2 text-slate-400" id="mobile-menu-btn">
						<Menu size={24} />
					</button>
				</div>
			</nav>
		</header>

		<!-- Main Content Section -->
		<main class="flex-grow max-w-7xl mx-auto w-full px-6 md:px-12 py-12 premium-gradient relative overflow-hidden">
			<!-- Subtle ambient animated glows -->
			<div class="absolute -top-40 -left-40 w-96 h-96 bg-brand-primary/10 rounded-full blur-[128px] pointer-events-none"></div>
			<div class="absolute -bottom-40 -right-40 w-96 h-96 bg-brand-secondary/10 rounded-full blur-[128px] pointer-events-none"></div>
			
			<slot />
		</main>

		<!-- Footer -->
		<footer class="border-t border-white/5 py-12 px-6 md:px-12 bg-slate-950">
			<div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-10 opacity-75">
				<div>
					<div class="font-serif text-2xl font-black italic mb-4">AstroBlog</div>
					<p class="text-sm leading-relaxed text-slate-400">Transformando ideias em código, design em experiência. Um blog premium totalmente open-source.</p>
				</div>
				<div>
					<h4 class="font-bold text-white mb-4 uppercase text-sm tracking-widest">Links Rápidos</h4>
					<ul class="space-y-3 text-sm text-slate-400">
						<li><a href="/" class="hover:text-brand-primary transition-colors">Início</a></li>
						<li><a href="/blog" class="hover:text-brand-primary transition-colors">Blog</a></li>
						<li><a href="/quem-sou-eu" class="hover:text-brand-primary transition-colors">Sobre Nós</a></li>
						<li><a href="/contato" class="hover:text-brand-primary transition-colors">Contato</a></li>
						<li><a href="/legal" class="hover:text-brand-primary transition-colors">Política de Privacidade</a></li>
					</ul>
				</div>
				<div class="relative min-h-[80px]">
					<h4 class="font-bold text-white mb-4 uppercase text-sm tracking-widest">Newsletter</h4>
					<form id="newsletter-form" name="newsletter" method="POST" data-netlify="true" data-netlify-honeypot="bot-field" class="flex gap-2 transition-all duration-500">
						<input type="hidden" name="form-name" value="newsletter" />
						<p class="hidden"><label>Don't fill this out if you're human: <input name="bot-field" /></label></p>
						<input type="email" name="email" required placeholder="Seu email..." class="bg-white/5 border border-white/10 rounded-lg px-4 py-2 text-sm focus:outline-none focus:border-brand-primary transition-all w-full" />
						<button type="submit" class="bg-brand-primary text-white font-bold py-2 px-4 rounded-lg hover:scale-105 active:scale-95 transition-all text-sm shrink-0">Inscrever</button>
					</form>
					<div id="newsletter-success" class="hidden mt-3 text-emerald-400 font-bold text-sm items-center gap-2 animate-pulse">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
						Obrigado! Sua inscrição foi confirmada.
					</div>
				</div>
			</div>
			<div class="max-w-7xl mx-auto mt-12 pt-8 border-t border-white/5 text-center text-xs text-slate-500">
				&copy; {new Date().getFullYear()} AstroBlog. Crafted with ❤️ and Astro.
			</div>
		</footer>

		<script is:inline>
			function setupLayout() {
				// Theme Toggle Logic
				const themeToggle = document.querySelector('#theme-toggle');
				const html = document.documentElement;
				
				// Initialize theme
				const storedTheme = localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
				html.classList.toggle('dark', storedTheme === 'dark');

				if (themeToggle) {
					themeToggle.addEventListener('click', () => {
						const isDark = html.classList.toggle('dark');
						localStorage.setItem('theme', isDark ? 'dark' : 'light');
					});
				}

				// Mobile Menu Logic
				const mobileBtn = document.querySelector('#mobile-menu-btn');
				const navMenu = document.querySelector('.md:flex.items-center.space-x-8');
				
				if (mobileBtn && navMenu) {
					mobileBtn.addEventListener('click', () => {
						navMenu.classList.toggle('hidden');
						navMenu.classList.toggle('flex-col');
						navMenu.classList.toggle('absolute');
						navMenu.classList.toggle('top-20');
						navMenu.classList.toggle('left-0');
						navMenu.classList.toggle('w-full');
						navMenu.classList.toggle('bg-slate-950');
						navMenu.classList.toggle('p-6');
						navMenu.classList.toggle('border-b');
						navMenu.classList.toggle('border-white/5');
						navMenu.classList.toggle('z-40');
					});
				}

				// Progress Bar (only on long pages)
				const progressBar = document.createElement('div');
				progressBar.className = 'fixed top-0 left-0 h-1 bg-gradient-to-r from-brand-primary to-brand-secondary z-[100] transition-all duration-300 pointer-events-none w-0';
				document.body.appendChild(progressBar);

				window.addEventListener('scroll', () => {
					const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
					const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
					const scrolled = (winScroll / height) * 100;
					progressBar.style.width = scrolled + "%";
					progressBar.style.opacity = scrolled > 1 ? "1" : "0";
				});
				
				// Newsletter AJAX submission
				const form = document.querySelector('#newsletter-form');
				const successMsg = document.querySelector('#newsletter-success');

				if (form) {
					form.addEventListener('submit', (e) => {
						e.preventDefault();
						const formData = new FormData(form);
						
						fetch('/', {
							method: 'POST',
							headers: { "Content-Type": "application/x-www-form-urlencoded" },
							body: new URLSearchParams(formData).toString()
						})
						.then(() => {
							form.style.opacity = '0';
							form.style.pointerEvents = 'none';
							setTimeout(() => {
								form.style.display = 'none';
								successMsg.classList.remove('hidden');
								successMsg.classList.add('flex');
							}, 300);
						})
						.catch((error) => console.error('Erro na inscrição:', error));
					});
				}

				// Netlify Identity Login Redirect
				if (window.netlifyIdentity) {
					window.netlifyIdentity.on("init", user => {
						if (!user) {
							window.netlifyIdentity.on("login", () => {
								document.location.href = "/admin/";
							});
						}
					});
				}
			}

			// Run on initial load
			setupLayout();

			// Run after every transition
			document.addEventListener('astro:after-swap', setupLayout);
		</script>
	</body>
</html>
