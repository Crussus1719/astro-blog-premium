---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { ArrowUpRight, Clock, Tag } from 'lucide-astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 3);
---

<Layout title="Home">
	<!-- Hero Section -->
	<section class="min-h-[70vh] flex flex-col items-center justify-center text-center py-20 relative px-4">
		<h1 class="text-5xl md:text-8xl font-black italic mb-6 leading-tight tracking-tighter text-white drop-shadow-2xl">
			O Futuro da <br/> <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-primary to-brand-secondary">Engenharia Digital</span>
		</h1>
		<p class="max-w-2xl text-lg md:text-xl text-slate-400 mb-10 leading-relaxed font-medium">
			Explorando as fronteiras do desenvolvimento web com Astro, Tailwind e as melhores práticas de SEO e Design.
		</p>
		<div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
			<a href="/blog" class="bg-brand-primary text-white font-bold py-4 px-8 rounded-2xl flex items-center justify-center space-x-2 animated-glow transition-all hover:scale-105">
				<span>Explorar Blog</span>
				<ArrowUpRight size={20} />
			</a>
			<a href="#featured" class="glass-effect text-white font-bold py-4 px-8 rounded-2xl flex items-center justify-center hover:bg-white/10 transition-all">
				Ver Destaques
			</a>
		</div>
	</section>

	<!-- Featured Posts Grid -->
	<section id="featured" class="py-20 mt-10">
		<div class="flex items-center justify-between mb-12">
			<h2 class="text-3xl font-serif">Posts Recentes</h2>
			<a href="/blog" class="text-sm font-bold text-brand-primary hover:underline uppercase tracking-widest">Ver Todos</a>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
			{posts.length > 0 ? posts.map((post) => (
				<article class="group glass-effect rounded-[2rem] overflow-hidden flex flex-col host-fade-in hover:border-brand-primary/30 transition-all duration-500">
					<div class="aspect-video relative overflow-hidden">
						<img 
							src={post.data.heroImage} 
							alt={post.data.title} 
							class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" 
						/>
						<div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-transparent to-transparent opacity-60"></div>
						<span class="absolute top-4 left-4 glass-effect text-[10px] font-black uppercase tracking-[0.2em] px-3 py-1 rounded-full text-brand-secondary">
							{post.data.category}
						</span>
					</div>
					<div class="p-8 flex flex-col flex-grow">
						<div class="flex items-center space-x-4 text-slate-500 text-xs mb-4 font-semibold">
							<div class="flex items-center space-x-1">
								<Clock size={14} />
								<span>{post.data.pubDate.toLocaleDateString('pt-BR', { month: 'long', day: 'numeric' })}</span>
							</div>
							<div class="flex items-center space-x-1">
								<Tag size={14} />
								<span>{post.data.tags[0] || 'Geral'}</span>
							</div>
						</div>
						<h3 class="text-xl font-bold mb-4 line-clamp-2 leading-snug group-hover:text-brand-primary transition-colors">
							{post.data.title}
						</h3>
						<p class="text-slate-400 text-sm line-clamp-3 mb-6 flex-grow leading-relaxed">
							{post.data.description}
						</p>
						<a href={`/blog/${post.slug}`} class="text-sm font-bold flex items-center space-x-2 text-white hover:text-brand-primary transition-colors group/link">
							<span>Ler Artigo</span>
							<ArrowUpRight size={16} class="transition-transform group-hover/link:translate-x-1 group-hover/link:-translate-y-1" />
						</a>
					</div>
				</article>
			)) : (
				<div class="col-span-1 md:col-span-3 py-20 text-center glass-effect rounded-3xl">
					<p class="text-slate-500 italic">Nenhum post publicado ainda. Prepare seu primeiro conteúdo no CMS!</p>
				</div>
			)}
		</div>
	</section>

	<!-- Call to Action -->
	<section class="mt-20 py-16 px-10 rounded-[3rem] bg-gradient-to-br from-brand-primary/20 via-brand-secondary/20 to-slate-900 border border-white/5 flex flex-col md:flex-row items-center justify-between gap-10">
		<div class="max-w-xl">
			<h2 class="text-4xl font-serif mb-4 italic">Pronto para criar conteúdo incrível?</h2>
			<p class="text-slate-400 font-medium">Use o Decap CMS pré-configurado para editar seu blog diretamente pelo GitHub sem escrever uma linha de código.</p>
		</div>
		<a href="/admin" class="bg-white text-slate-950 px-10 py-5 rounded-2xl font-black text-lg transition-transform hover:scale-105 hover:rotate-2 shadow-2xl active:scale-95 text-center flex-shrink-0">
			Acessar Painel
		</a>
	</section>
</Layout>
