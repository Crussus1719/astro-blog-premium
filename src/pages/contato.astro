---
import Layout from '../layouts/Layout.astro';
import { Mail, MapPin, Send } from 'lucide-astro';
---

<Layout title="Contato" description="Entre em contato conosco para parcerias, dúvidas ou sugestões.">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 items-start py-12">
        <!-- Text Content -->
        <div class="space-y-8 animate-fade-in">
            <div class="space-y-4">
                <h1 class="text-5xl font-serif font-black italic text-white leading-tight">Vamos construir <br/> algo <span class="text-brand-primary">incrível</span>?</h1>
                <p class="text-lg text-slate-400 max-w-md">Estou sempre aberto a novas ideias, colaborações ou apenas para bater um papo sobre o futuro da tecnologia.</p>
            </div>

            <div class="space-y-6">
                <div class="flex items-center space-x-4 group p-4 rounded-2xl glass-effect border border-white/5 hover:border-brand-primary/20 transition-all">
                    <div class="p-3 bg-brand-primary/10 rounded-xl text-brand-primary group-hover:scale-110 transition-transform">
                        <Mail size={24} />
                    </div>
                    <div>
                        <p class="text-xs font-bold text-slate-500 uppercase tracking-widest">E-mail</p>
                        <p class="text-white font-semibold">contato@to2343.netlify.app</p>
                    </div>
                </div>

                <div class="flex items-center space-x-4 group p-4 rounded-2xl glass-effect border border-white/5 hover:border-brand-primary/20 transition-all">
                    <div class="p-3 bg-brand-secondary/10 rounded-xl text-brand-secondary group-hover:scale-110 transition-transform">
                        <MapPin size={24} />
                    </div>
                    <div>
                        <p class="text-xs font-bold text-slate-500 uppercase tracking-widest">Localização</p>
                        <p class="text-white font-semibold">São Paulo, Brasil</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Contact Form -->
        <div class="glass-effect p-8 md:p-10 rounded-3xl border border-white/10 shadow-2xl relative overflow-hidden group">
            <div class="absolute -top-24 -right-24 w-48 h-48 bg-brand-primary/10 rounded-full blur-[80px] group-hover:bg-brand-primary/20 transition-colors"></div>
            
            <form 
                name="contact" 
                method="POST" 
                data-netlify="true" 
                class="space-y-6 relative z-10"
                id="contact-form"
            >
                <input type="hidden" name="form-name" value="contact" />
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-2">
                        <label for="name" class="text-sm font-bold text-slate-300 ml-1">Nome</label>
                        <input type="text" name="name" id="name" required class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-brand-primary transition-all text-white placeholder:text-slate-600" placeholder="Seu nome" />
                    </div>
                    <div class="space-y-2">
                        <label for="email" class="text-sm font-bold text-slate-300 ml-1">E-mail</label>
                        <input type="email" name="email" id="email" required class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-brand-primary transition-all text-white placeholder:text-slate-600" placeholder="seu@email.com" />
                    </div>
                </div>

                <div class="space-y-2">
                    <label for="subject" class="text-sm font-bold text-slate-300 ml-1">Assunto</label>
                    <input type="text" name="subject" id="subject" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-brand-primary transition-all text-white placeholder:text-slate-600" placeholder="No que posso ajudar?" />
                </div>

                <div class="space-y-2">
                    <label for="message" class="text-sm font-bold text-slate-300 ml-1">Mensagem</label>
                    <textarea name="message" id="message" rows="5" required class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-brand-primary transition-all text-white placeholder:text-slate-600" placeholder="Escreva sua mensagem aqui..."></textarea>
                </div>

                <button type="submit" class="w-full bg-gradient-to-r from-brand-primary to-brand-secondary text-white font-black py-4 rounded-xl hover:shadow-[0_0_30px_rgba(var(--brand-primary-rgb),0.4)] hover:scale-[1.02] active:scale-[0.98] transition-all flex items-center justify-center space-x-2 tracking-widest uppercase text-sm">
                    <span>Enviar Mensagem</span>
                    <Send size={18} />
                </button>
            </form>

            <div id="contact-success" class="hidden absolute inset-0 bg-slate-950/90 backdrop-blur-sm z-20 flex flex-col items-center justify-center text-center p-8 animate-fade-in">
                <div class="w-20 h-20 bg-brand-primary/20 rounded-full flex items-center justify-center text-brand-primary mb-6 animate-bounce">
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                </div>
                <h3 class="text-2xl font-serif italic text-white mb-2">Mensagem Enviada!</h3>
                <p class="text-slate-400">Obrigado pelo contato. Responderei o mais breve possível.</p>
                <button onclick="location.reload()" class="mt-8 text-brand-primary text-sm font-bold hover:underline">Enviar outra mensagem</button>
            </div>
        </div>
    </div>

    <script is:inline>
        const contactForm = document.querySelector('#contact-form');
        const contactSuccess = document.querySelector('#contact-success');

        if (contactForm) {
            contactForm.addEventListener('submit', (e) => {
                e.preventDefault();
                const formData = new FormData(contactForm);
                
                fetch('/', {
                    method: 'POST',
                    headers: { "Content-Type": "application/x-www-form-urlencoded" },
                    body: new URLSearchParams(formData).toString()
                })
                .then(() => {
                    contactSuccess.classList.remove('hidden');
                    contactSuccess.classList.add('flex');
                })
                .catch((error) => console.error('Erro no envio:', error));
            });
        }
    </script>
</Layout>
